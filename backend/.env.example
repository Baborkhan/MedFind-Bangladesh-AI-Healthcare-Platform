# MedFind Bangladesh - Local Development Environment
# Copy this file to .env and fill in your values
# NEVER commit .env to git

DEBUG=True
SECRET_KEY=medfind-local-dev-secret-key-change-this

# Database (SQLite used locally by default - no config needed)
# DB_NAME=medfind
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432

# For Render PostgreSQL (alternative):
# DATABASE_URL=postgresql://user:password@host:5432/medfind

# MongoDB (optional - for analytics)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_NAME=medfind

# Redis (optional locally)
REDIS_URL=redis://127.0.0.1:6379/0

# AI - Gemini (get from: aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-lite

# AI - Anthropic Claude (optional)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Email OTP (Gmail App Password)
# Gmail -> Account -> Security -> 2-Step -> App passwords
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Hosts
ALLOWED_HOSTS=localhost,127.0.0.1
